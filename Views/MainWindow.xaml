<Window
    x:Class="Budweg.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Budweg"
    Width="400"
    Height="700"
    Background="White"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="BudwegGreen" Color="#FF00A651" />
        <SolidColorBrush x:Key="BudwegGreenHover" Color="#FF009148" />
        <SolidColorBrush x:Key="BudwegRed" Color="#FFC8372D" />
        <SolidColorBrush x:Key="BudwegRedHover" Color="#FFB32C23" />

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="CardBorder"
                            Height="200"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="56"
                                    Text="{TemplateBinding Tag}" />
                                <TextBlock
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Text="{TemplateBinding Content}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource BudwegGreenHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" Background="{StaticResource BudwegGreen}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Logo block  -->
            <Border
                Grid.Column="0"
                Margin="24,18"
                Padding="24,12"
                Background="White"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="{StaticResource BudwegGreen}"
                        Text="BUDWEG" />
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource BudwegGreen}"
                        Text="BETTER BE SAFE" />
                </StackPanel>
            </Border>

            <!--  Close X  -->
            <Button
                Grid.Column="2"
                Margin="24,18"
                Background="Transparent"
                BorderThickness="0"
                Click="Close_Click"
                Content="&#xE711;"
                FontFamily="Segoe MDL2 Assets"
                FontSize="28"
                Foreground="White" />
        </Grid>

        <!--  Grid of Cards  -->
        <Grid Grid.Row="1" Margin="24">

            <!--  Opret Kaliber  -->
            <Button
                x:Name="CreateButton"
                Background="{StaticResource BudwegGreen}"
                Click="Create_Click"
                Content="Opret Kaliber"
                Style="{StaticResource CardButtonStyle}"
                Tag="&#xE710;" />


        </Grid>
    </Grid>
</Window>
